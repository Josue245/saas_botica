APP_NAME="Mi Botica"
APP_ENV=testing
APP_KEY=base64:04P8ewBrMHnlOBfNEdxxi4h7CHw2FODB3aJUqo76kiY=
APP_DEBUG=true
APP_TIMEZONE="America/Lima"
APP_URL=http://localhost:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_LEVEL=debug

# IMPORTANTE: apunta al contenedor mysql_testing (puerto interno 3306, no 3307)
# Esta BD vive en tmpfs y se destruye al apagar el contenedor — nunca toca producción.
DB_CONNECTION=mysql
DB_HOST=mysql_testing
DB_PORT=3306
DB_DATABASE=saas_botica_testing
DB_USERNAME=botica
DB_PASSWORD=botica_local_only

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=array

MAIL_MAILER=array
MAIL_FROM_ADDRESS="no-reply@mibotica.test"
MAIL_FROM_NAME="${APP_NAME}"
